# ─────────────────────────────────────────────────────────────
# DATABASE
# Local dev: matches docker-compose.yml. Production: Supabase or Neon connection string.
# ─────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://qt:qt_dev_password@localhost:5432/quarterly_theory?schema=public"
# Neon/Supabase pooled connection (for serverless/edge) — falls back to DATABASE_URL if unset.
DIRECT_URL="postgresql://qt:qt_dev_password@localhost:5432/quarterly_theory?schema=public"

# ─────────────────────────────────────────────────────────────
# AUTH.JS
# Generate AUTH_SECRET with: npx auth secret
# ─────────────────────────────────────────────────────────────
AUTH_SECRET="replace-with-a-real-generated-secret"
NEXTAUTH_URL="http://localhost:3000"

# OAuth providers — create credentials in Google Cloud Console / Apple Developer Portal.
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_APPLE_ID=""
AUTH_APPLE_SECRET=""

# ─────────────────────────────────────────────────────────────
# STRIPE — from https://dashboard.stripe.com/apikeys
# ─────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_ID_MONTHLY="price_..."
STRIPE_PRICE_ID_ANNUAL="price_..."

# ─────────────────────────────────────────────────────────────
# TRANSACTIONAL EMAIL — integration point, provider-agnostic.
# Recommended: Resend (https://resend.com). See lib/email.ts.
# ─────────────────────────────────────────────────────────────
RESEND_API_KEY=""
EMAIL_FROM="Quarterly Theory <noreply@quarterlytheory.app>"

# ─────────────────────────────────────────────────────────────
# RATE LIMITING — integration point. Recommended: Upstash Redis.
# See lib/rate-limit.ts. Falls back to an in-memory limiter in dev
# if these are unset (NOT safe for multi-instance production).
# ─────────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ─────────────────────────────────────────────────────────────
# FILE STORAGE — integration point for trade screenshots, avatars.
# Recommended: Vercel Blob or AWS S3.
# ─────────────────────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=""

# ─────────────────────────────────────────────────────────────
# AI ASSISTANT — Anthropic API for the AI Assistant module.
# ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=""

# ─────────────────────────────────────────────────────────────
# APP
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
